{
  "market_data": {
    "exchange": "alpaca",
    "symbols": [
      "AAPL",
      "MSFT",
      "GOOGL",
      "AMZN",
      "TSLA",
      "NVDA",
      "META",
      "NFLX"
    ],
    "websocket_url": "wss://stream.data.alpaca.markets/v2/iex",
    "reconnect_delay_ms": 3000,
    "zmq_publish_address": "tcp://0.0.0.0:5555"
  },
  "risk": {
    "max_position_size": 250.0,
    "max_notional_exposure": 10000.0,
    "max_open_positions": 2,
    "stop_loss_percent": 1.0,
    "trailing_stop_percent": 0.75,
    "enable_circuit_breaker": true,
    "max_loss_threshold": 1000.0,
    "sizing_amount": 0.0
  },
  "execution": {
    "exchange_api_url": "https://paper-api.alpaca.markets/v2",
    "api_key": null,
    "api_secret": null,
    "rate_limit_per_second": 200,
    "retry_attempts": 5,
    "retry_delay_ms": 500,
    "paper_trading": true,
    "max_slippage_bps": 50.0
  },
  "signal": {
    "model_path": "models/trading_model.pkl",
    "features": [
      "rsi",
      "macd",
      "macd_signal",
      "macd_histogram",
      "bollinger_bands",
      "bollinger_upper",
      "bollinger_lower",
      "moving_average_20",
      "moving_average_50",
      "moving_average_200",
      "volume_ratio",
      "price_momentum",
      "atr",
      "obv"
    ],
    "update_interval_ms": 500,
    "zmq_subscribe_address": "tcp://market-data:5555",
    "zmq_publish_address": "tcp://0.0.0.0:5556"
  },
  "metadata": {
    "environment": "staging",
    "version": "1.0.0",
    "description": "Managed SaaS staging profile with paper trading and production-like service boundaries",
    "service_mode": "managed_saas",
    "tenancy_mode": "multi_tenant",
    "audiences": "developer,trader,regular",
    "billing_model": "subscription_and_usage",
    "public_entrypoints": "nextjs-frontend,edge-gateway",
    "private_services": "market-data,signal-bridge,risk-manager,execution-engine,go-control-plane,managed-redis",
    "config_owner": "platform"
  }
}

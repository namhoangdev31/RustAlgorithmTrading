generator client {
  provider            = "prisma-client"
  output              = "./generated"
  importFileExtension = "ts"
}

generator pothos {
  provider          = "prisma-pothos-types"
  clientOutput      = "../prisma/generated/"
  output            = "../lib/pothos-prisma-types.ts"
  generateDatamodel = "true"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model Order {
  id          Int      @id @default(autoincrement())
  orderId     String   @unique @map("order_id") @db.VarChar(255)
  symbol      String   @db.VarChar(50)
  side        String   @db.VarChar(10)
  orderType   String   @map("order_type") @db.VarChar(50)
  quantity    Float
  price       Float?
  status      String   @db.VarChar(50)
  submittedAt DateTime @map("submitted_at") @db.Timestamptz

  @@map("orders")
}

model RiskEvent {
  id         Int      @id @default(autoincrement())
  eventType  String   @map("event_type") @db.VarChar(50)
  severity   String   @db.VarChar(20)
  message    String
  metadata   Json?
  occurredAt DateTime @map("occurred_at") @db.Timestamptz

  @@map("risk_events")
}

model File {
  id          String  @id @db.Uuid
  path        String  @db.VarChar(500)
  bucket      String? @db.VarChar(255)
  size        BigInt?
  contentType String? @map("contentType") @db.VarChar(255)
  filename    String? @db.VarChar(255)
  mimetype    String? @db.VarChar(255)

  usersWithPhoto User[] @relation("UserPhoto")

  @@map("files")
}

model User {
  id           String    @id @db.Uuid
  email        String?   @unique @db.VarChar(255)
  password     String?   @db.VarChar(255)
  provider     String    @default("email") @db.VarChar(255)
  socialId     String?   @map("socialId") @db.VarChar(255)
  firstName    String?   @map("firstName") @db.VarChar(255)
  lastName     String?   @map("lastName") @db.VarChar(255)
  fullName     String?   @map("fullName") @db.VarChar(255)
  phone        String?   @unique @db.VarChar(255)
  dateOfBirth  DateTime? @map("dateOfBirth") @db.Timestamp(6)
  gender       String?   @db.VarChar(50)
  userType     String    @default("individual") @map("userType") @db.VarChar(50)
  photoId      String?   @map("photoId") @db.Uuid
  registerType String?   @map("registerType") @db.VarChar(50)
  createdAt    DateTime  @map("createdAt") @db.Timestamp(6)
  updatedAt    DateTime  @map("updatedAt") @db.Timestamp(6)
  deletedAt    DateTime? @map("deletedAt") @db.Timestamp(6)

  // Relations
  photo File? @relation("UserPhoto", fields: [photoId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  payouts                BundlePayouts[]
  organizations          Organization[]
  notificationsActor     Notifications[]             @relation("NotificationActor")
  notificationsRecipient Notifications[]             @relation("NotificationRecipient")
  sessions               Session[]
  deviceTokens           UserDeviceToken[]
  analytics              BundleAnalyticsEvents[]
  auditLogs              BundleAuditLog[]
  betaTesters            BundleBetaTesters[]
  changedLogs            BundleChangeLogs[]
  collaboratorsInvited   BundleCollaborators[]       @relation("CollaboratorInvitedBy")
  collaborators          BundleCollaborators[]       @relation("CollaboratorUser")
  developerStrikes       BundleDeveloperStrikes[]    @relation("StrikeDeveloper")
  developerStrikesIssued BundleDeveloperStrikes[]    @relation("StrikeIssuedBy")
  installEvents          BundleInstallEvents[]
  orders                 BundleOrders[]
  reviews                BundleReviews[]
  stateTransitions       BundleStateTransitions[]
  userReportsReported    BundleUserReports[]         @relation("ReportReportedBy")
  userReportsReviewed    BundleUserReports[]         @relation("ReportReviewedBy")
  refundRequestsReviewed BundleRefundRequests[]      @relation("RefundReviewedBy")
  refundRequests         BundleRefundRequests[]      @relation("RefundUser")
  userEntitlements       BundleUserEntitlements[]
  reviewReportsReported  BundleReviewReports[]       @relation("ReviewReportReportedBy")
  reviewReportsReviewed  BundleReviewReports[]       @relation("ReviewReportReviewedBy")
  subscriptionHistory    BundleSubscriptionHistory[]
  reviewHistory          BundleReviewHistory[]
  reviewQueueReviewed    BundleReviewQueue[]         @relation("ReviewQueueReviewer")

  @@map("users")
}

enum OrganizationType {
  personal
  corporate
}

model Organization {
  id        String           @id @db.Uuid
  name      String           @db.VarChar(255)
  type      OrganizationType
  userId    String           @map("user_id") @db.Uuid
  createdAt DateTime         @map("created_at") @db.Timestamp(6)
  updatedAt DateTime         @map("updated_at") @db.Timestamp(6)
  deletedAt DateTime?        @map("deleted_at") @db.Timestamp(6)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@unique([userId, type])
  @@map("organizations")
}

model Project {
  id             String    @id @db.Uuid
  name           String    @db.VarChar(255)
  description    String?
  organizationId String    @map("organization_id") @db.Uuid
  createdAt      DateTime  @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime  @map("updated_at") @db.Timestamp(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamp(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bundle       Bundles?

  @@map("projects")
}

model BundlePayouts {
  id             String   @id @db.Uuid
  developerId    String   @map("developer_id") @db.Uuid
  amount         Float
  currency       String   @default("VND") @db.VarChar(10)
  periodStart    BigInt   @map("period_start")
  periodEnd      BigInt   @map("period_end")
  status         String   @default("pending") @db.VarChar(30)
  bankAccount    String?  @map("bank_account") @db.VarChar(255)
  transactionRef String?  @map("transaction_ref") @db.VarChar(255)
  createdAt      DateTime @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime @map("updated_at") @db.Timestamp(6)

  developer User @relation(fields: [developerId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([developerId], map: "bundle_payouts_developer_id")
  @@index([status], map: "bundle_payouts_status")
  @@map("bundle_payouts")
}

model Bundles {
  id                String    @id @db.Uuid
  bundleKey         String?   @unique @map("bundle_key") @db.VarChar(255)
  name              String    @db.VarChar(255)
  slug              String?   @unique @db.VarChar(255)
  version           String    @default("1.0.0") @db.VarChar(50)
  buildNumber       Int       @default(1) @map("build_number")
  iconUrl           String?   @map("icon_url") @db.VarChar(500)
  bannerUrl         String?   @map("banner_url") @db.VarChar(500)
  shortDescription  String?   @map("short_description") @db.VarChar(255)
  description       String?
  privacyPolicyUrl  String?   @map("privacy_policy_url") @db.VarChar(500)
  supportUrl        String?   @map("support_url") @db.VarChar(500)
  websiteUrl        String?   @map("website_url") @db.VarChar(500)
  developerName     String?   @map("developer_name") @db.VarChar(255)
  developerId       String?   @map("developer_id") @db.Uuid
  developerEmail    String?   @map("developer_email") @db.VarChar(255)
  category          String?   @db.VarChar(100)
  subCategory       String?   @map("sub_category") @db.VarChar(100)
  storagePath       String    @map("storage_path") @db.VarChar(500)
  bucket            String    @db.VarChar(100)
  fileSize          BigInt?   @map("file_size")
  checksum          String?   @db.VarChar(128)
  price             Float?
  currency          String?   @db.VarChar(10)
  isFree            Boolean   @default(true) @map("is_free")
  isOneTimePayment  Boolean   @default(false) @map("is_one_time_payment")
  hasInAppPurchases Boolean   @default(false) @map("has_in_app_purchases")
  hasSubscription   Boolean   @default(false) @map("has_subscription")
  status            String    @default("draft") @db.VarChar(50)
  rejectionReason   String?   @map("rejection_reason")
  publishedAt       DateTime? @map("published_at") @db.Timestamp(6)
  expiresAt         DateTime? @map("expires_at") @db.Timestamp(6)
  changelog         String?
  releaseNotes      String?   @map("release_notes")
  ageRating         String?   @map("age_rating") @db.VarChar(10)
  contentAdvisory   String?   @map("content_advisory")
  createdAt         DateTime  @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime  @map("updated_at") @db.Timestamp(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamp(6)

  projectId String?  @unique @map("project_id") @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  abTests              BundleAbTests[]
  abuseSignals         BundleAbuseSignals?
  adConfigurations     BundleAdConfigurations?
  analyticsEvents      BundleAnalyticsEvents[]
  apiUsageStats        BundleApiUsageStats[]
  auditLogs            BundleAuditLog[]
  betaTesters          BundleBetaTesters[]
  changeLogs           BundleChangeLogs[]
  collaborators        BundleCollaborators[]
  contentRatings       BundleContentRatings[]
  countries            BundleCountries[]
  dependencies         BundleDependencies[]         @relation("BundleSource")
  dependentBundles     BundleDependencies[]         @relation("BundleDependency")
  developerStrikes     BundleDeveloperStrikes[]
  deviceSupports       BundleDeviceSupport[]
  externalIntegrations BundleExternalIntegrations[]
  featuredSlots        BundleFeaturedSlots[]
  inAppPurchases       BundleInAppPurchases[]
  installEvents        BundleInstallEvents[]
  languages            BundleLanguages[]
  localizations        BundleLocalizations[]
  monetizationConfigs  BundleMonetizationConfigs?
  orders               BundleOrders[]
  permissions          BundlePermissions[]
  privacyDeclarations  BundlePrivacyDeclarations?
  promotions           BundlePromotions[]
  rankingScores        BundleRankingScores?
  releaseTracks        BundleReleaseTracks[]
  retentionStats       BundleRetentionStats[]
  reviews              BundleReviews[]
  runtimeConfig        BundleRuntimeConfig?
  screenshots          BundleScreenshots[]
  searchKeywords       BundleSearchKeywords[]
  stateTransitions     BundleStateTransitions[]
  stats                BundleStats?
  storeFlags           BundleStoreFlags?
  storeListings        BundleStoreListings[]
  subscriptionPlans    BundleSubscriptionPlans[]
  tags                 BundleTags[]
  trendingSnapshots    BundleTrendingSnapshots[]
  userReports          BundleUserReports[]
  versionHistories     BundleVersionHistory[]
  webhooks             BundleWebhooks[]
  userEntitlements     BundleUserEntitlements[]
  rollouts             BundleRollouts[]
  subscriptionHistory  BundleSubscriptionHistory[]
  crashReports         BundleCrashReports[]
  reviewHistory        BundleReviewHistory[]
  reviewQueue          BundleReviewQueue[]
  securityScanResults  BundleSecurityScanResults[]
  updatePhases         BundleUpdatePhases[]

  @@index([category, status], map: "bundles_category_status")
  @@index([createdAt], map: "bundles_created_at")
  @@index([status], map: "bundles_status")
  @@map("bundles")
}

model Notifications {
  id           String    @id @db.Uuid
  title        String    @db.VarChar(255)
  body         String?
  type         String    @db.VarChar(50)
  isRead       Boolean   @default(false) @map("isRead")
  readAt       DateTime? @map("readAt") @db.Timestamp(6)
  recipientId  String    @map("recipientId") @db.Uuid
  actorId      String?   @map("actorId") @db.Uuid
  resourceId   String?   @map("resourceId") @db.Uuid
  resourceType String?   @map("resourceType") @db.VarChar(50)
  metadata     String?
  createdAt    DateTime  @map("createdAt") @db.Timestamp(6)
  updatedAt    DateTime  @map("updatedAt") @db.Timestamp(6)
  deletedAt    DateTime? @map("deletedAt") @db.Timestamp(6)

  actor     User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@map("notifications")
}

model Session {
  id        String    @id @db.Uuid
  userId    String    @map("userId") @db.Uuid
  hash      String    @db.VarChar(255)
  createdAt DateTime  @map("createdAt") @db.Timestamp(6)
  updatedAt DateTime  @map("updatedAt") @db.Timestamp(6)
  deletedAt DateTime? @map("deletedAt") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@map("sessions")
}

model UserDeviceToken {
  id          String   @id @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  fcmToken    String   @map("fcmToken") @db.VarChar(500)
  platform    String   @db.VarChar(20)
  deviceModel String?  @map("deviceModel") @db.VarChar(255)
  osVersion   String?  @map("osVersion") @db.VarChar(50)
  isActive    Boolean  @default(true) @map("isActive")
  createdAt   DateTime @map("createdAt") @db.Timestamp(6)
  updatedAt   DateTime @map("updatedAt") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@map("user_device_token")
}

model BundleAbTests {
  id             String    @id @db.Uuid
  bundleId       String    @map("bundle_id") @db.Uuid
  testName       String    @map("test_name") @db.VarChar(255)
  hypothesis     String?
  variantAConfig String    @map("variant_a_config")
  variantBConfig String    @map("variant_b_config")
  metric         String    @db.VarChar(100)
  trafficSplit   Int       @default(50) @map("traffic_split")
  status         String    @default("draft") @db.VarChar(20)
  winnerVariant  String?   @map("winner_variant") @db.VarChar(5)
  startedAt      DateTime? @map("started_at") @db.Timestamp(6)
  endedAt        DateTime? @map("ended_at") @db.Timestamp(6)
  createdAt      DateTime  @map("created_at") @db.Timestamp(6)

  bundle Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([bundleId], map: "bundle_ab_tests_bundle_id")
  @@index([status], map: "bundle_ab_tests_status")
  @@map("bundle_ab_tests")
}

model BundleAbuseSignals {
  id                      String   @id @db.Uuid
  bundleId                String   @unique @map("bundle_id") @db.Uuid
  fakeReviewScore         Float    @default(0.0) @map("fake_review_score")
  suspiciousInstallRate   Float    @default(0.0) @map("suspicious_install_rate")
  anomalyScore            Float    @default(0.0) @map("anomaly_score")
  clickFarmScore          Float    @default(0.0) @map("click_farm_score")
  ratingManipulationScore Float    @default(0.0) @map("rating_manipulation_score")
  overallRiskScore        Float    @default(0.0) @map("overall_risk_score")
  riskLevel               String   @default("low") @map("risk_level") @db.VarChar(20)
  lastCalculatedAt        DateTime @map("last_calculated_at") @db.Timestamp(6)
  flaggedForReview        Boolean  @default(false) @map("flagged_for_review")

  bundle Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([flaggedForReview], map: "bundle_abuse_signals_flagged_for_review")
  @@index([overallRiskScore], map: "bundle_abuse_signals_overall_risk_score")
  @@index([riskLevel], map: "bundle_abuse_signals_risk_level")
  @@map("bundle_abuse_signals")
}

model BundleAdConfigurations {
  id             String   @id @db.Uuid
  bundleId       String   @unique @map("bundle_id") @db.Uuid
  provider       String   @db.VarChar(50)
  appId          String   @map("app_id") @db.VarChar(255)
  bannerId       String?  @map("banner_id") @db.VarChar(255)
  interstitialId String?  @map("interstitial_id") @db.VarChar(255)
  rewardedId     String?  @map("rewarded_id") @db.VarChar(255)
  nativeId       String?  @map("native_id") @db.VarChar(255)
  isTestMode     Boolean  @default(false) @map("is_test_mode")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime @map("updated_at") @db.Timestamp(6)

  bundle Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("bundle_ad_configurations")
}

model BundleAnalyticsEvents {
  id              String   @id @db.Uuid
  bundleId        String   @map("bundle_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  sessionId       String?  @map("session_id") @db.VarChar(100)
  eventType       String   @map("event_type") @db.VarChar(50)
  eventData       String?  @map("event_data")
  platformVersion String?  @map("platform_version") @db.VarChar(20)
  bundleVersion   String?  @map("bundle_version") @db.VarChar(50)
  ipAddress       String?  @map("ip_address") @db.VarChar(45)
  createdAt       DateTime @map("created_at") @db.Timestamp(6)

  bundle Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([bundleId], map: "bundle_analytics_events_bundle_id")
  @@index([createdAt], map: "bundle_analytics_events_created_at")
  @@index([eventType], map: "bundle_analytics_events_event_type")
  @@map("bundle_analytics_events")
}

model BundleApiUsageStats {
  id           String   @id @db.Uuid
  bundleId     String   @map("bundle_id") @db.Uuid
  statsDate    String   @map("stats_date") @db.VarChar(10)
  endpoint     String   @db.VarChar(255)
  method       String   @db.VarChar(10)
  callCount    BigInt   @default(0) @map("call_count")
  errorCount   BigInt   @default(0) @map("error_count")
  avgLatencyMs Float?   @map("avg_latency_ms")
  p99LatencyMs Float?   @map("p99_latency_ms")
  createdAt    DateTime @map("created_at") @db.Timestamp(6)

  bundle Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([bundleId], map: "bundle_api_usage_stats_bundle_id")
  @@index([statsDate], map: "bundle_api_usage_stats_stats_date")
  @@map("bundle_api_usage_stats")
}

model BundleAuditLog {
  id          String   @id @db.Uuid
  bundleId    String   @map("bundle_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  action      String   @db.VarChar(50)
  fieldName   String?  @map("field_name") @db.VarChar(100)
  oldValue    String?  @map("old_value")
  countryCode String?  @map("country_code") @db.VarChar(5)
  createdAt   DateTime @map("created_at") @db.Timestamp(6)

  bundle Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([action], map: "bundle_audit_log_action")
  @@index([bundleId], map: "bundle_audit_log_bundle_id")
  @@index([countryCode], map: "bundle_audit_log_country_code")
  @@index([createdAt], map: "bundle_audit_log_created_at")
  @@map("bundle_audit_log")
}

model BundleBetaTesters {
  id         String    @id @db.Uuid
  bundleId   String    @map("bundle_id") @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  email      String    @db.VarChar(255)
  inviteCode String?   @unique @map("invite_code") @db.VarChar(64)
  status     String    @default("invited") @db.VarChar(30)
  expiresAt  DateTime? @map("expires_at") @db.Timestamp(6)
  createdAt  DateTime  @map("created_at") @db.Timestamp(6)

  bundle Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([bundleId, email])
  @@index([bundleId], map: "bundle_beta_testers_bundle_id")
  @@index([status], map: "bundle_beta_testers_status")
  @@map("bundle_beta_testers")
}

model BundleChangeLogs {
  id         String   @id @db.Uuid
  bundleId   String   @map("bundle_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.VarChar(50)
  changeType String   @map("change_type") @db.VarChar(30)
  diff       String
  changedBy  String?  @map("changed_by") @db.Uuid
  createdAt  DateTime @map("created_at") @db.Timestamp(6)

  bundle Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  user   User?   @relation(fields: [changedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([bundleId], map: "bundle_change_logs_bundle_id")
  @@index([changeType], map: "bundle_change_logs_change_type")
  @@index([createdAt], map: "bundle_change_logs_created_at")
  @@index([entityType], map: "bundle_change_logs_entity_type")
  @@map("bundle_change_logs")
}

model BundleCollaborators {
  id         String    @id @db.Uuid
  bundleId   String    @map("bundle_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  role       String    @default("editor") @db.VarChar(30)
  invitedBy  String?   @map("invited_by") @db.Uuid
  acceptedAt DateTime? @map("accepted_at") @db.Timestamp(6)
  createdAt  DateTime  @map("created_at") @db.Timestamp(6)

  bundle      Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  invitedUser User?   @relation("CollaboratorInvitedBy", fields: [invitedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  user        User    @relation("CollaboratorUser", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([bundleId, userId])
  @@map("bundle_collaborators")
}

model BundleContentRatings {
  id          String   @id @db.Uuid
  bundleId    String   @map("bundle_id") @db.Uuid
  ratingBoard String   @map("rating_board") @db.VarChar(20)
  rating      String   @db.VarChar(20)
  descriptors String?
  createdAt   DateTime @map("created_at") @db.Timestamp(6)

  bundle Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([bundleId, ratingBoard])
  @@map("bundle_content_ratings")
}

model BundleCountries {
  id            String  @id @db.Uuid
  bundleId      String  @map("bundle_id") @db.Uuid
  countryCode   String  @map("country_code") @db.VarChar(5)
  isAvailable   Boolean @default(true) @map("is_available")
  priceOverride Float?  @map("price_override")
  currency      String? @db.VarChar(10)

  bundle Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([bundleId, countryCode])
  @@map("bundle_countries")
}

model BundleDependencies {
  id                  String   @id @db.Uuid
  bundleId            String   @map("bundle_id") @db.Uuid
  dependencyBundleId  String   @map("dependency_bundle_id") @db.Uuid
  dependencyBundleKey String?  @map("dependency_bundle_key") @db.VarChar(255)
  minVersion          String?  @map("min_version") @db.VarChar(50)
  maxVersion          String?  @map("max_version") @db.VarChar(50)
  isOptional          Boolean  @default(false) @map("is_optional")
  createdAt           DateTime @map("created_at") @db.Timestamp(6)

  bundle           Bundles @relation("BundleSource", fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  dependencyBundle Bundles @relation("BundleDependency", fields: [dependencyBundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([bundleId, dependencyBundleId])
  @@map("bundle_dependencies")
}

model BundleDeveloperStrikes {
  id          String    @id @db.Uuid
  developerId String    @map("developer_id") @db.Uuid
  bundleId    String?   @map("bundle_id") @db.Uuid
  strikeType  String    @map("strike_type") @db.VarChar(50)
  severity    String    @default("minor") @db.VarChar(20)
  description String
  issuedBy    String?   @map("issued_by") @db.Uuid
  expiresAt   DateTime? @map("expires_at") @db.Timestamp(6)
  createdAt   DateTime  @map("created_at") @db.Timestamp(6)

  bundle    Bundles? @relation(fields: [bundleId], references: [id], onDelete: Restrict, onUpdate: Restrict)

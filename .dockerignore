# --- Docker Build Context Exclusions ---

# Git
.git
.gitignore
.gitattributes
.github/

# IDE & OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.gemini/
.agents/

# Build & Tooling (General)
target/
node_modules/
**/node_modules/
**/.next/
**/*.tsbuildinfo
coverage/
.nyc_output/
.cache/
.swarm/
pids/
*.pid
tmp/
temp/
*.tmp

# Python
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.venv/
venv/
env/
.tox/
.nox/
.coverage
htmlcov/
*.egg-info/
.installed.cfg
*.egg

# Rust
**/*.rs.bk
rust/target/

# Go
go/bin/
go/vendor/
go/observability-api
**/*.out
**/*.test

# Data & Databases (Should be mounted as volumes)
data/
**/*.db
**/*.duckdb
**/*.sqlite
**/*.sqlite3
**/*.csv
**/*.parquet

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment & Secrets (NEVER include in images)
.env
.env.local
.env.*.local
**/.env
**/.env.*
*.pem
*.key
*.cert
**/*.pem
**/*.key
**/*.cert
secrets/
**/secrets/

# Documentation (Optional, exclude if not needed for runtime)
docs/
medium/
*.md
LICENSE
README*

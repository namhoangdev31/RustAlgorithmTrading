  bundleId    String    @map("bundle_id") @db.Uuid
  version     String    @db.VarChar(50)
  buildNumber Int       @map("build_number")
  storagePath String    @map("storage_path") @db.VarChar(500)
  fileSize    BigInt?   @map("file_size")
  changelog   String?
  status      String    @default("archived") @db.VarChar(50)
  publishedAt DateTime? @map("published_at") @db.Timestamp(6)
  createdAt   DateTime  @map("created_at") @db.Timestamp(6)

  bundle Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  crashReports        BundleCrashReports[]
  reviewHistory       BundleReviewHistory[]
  reviewQueue         BundleReviewQueue[]
  securityScanResults BundleSecurityScanResults[]
  updatePhases        BundleUpdatePhases[]

  @@unique([bundleId, version, buildNumber])
  @@index([bundleId], map: "bundle_version_history_bundle_id")
  @@map("bundle_version_history")
}

model BundleWebhooks {
  id              String    @id @db.Uuid
  bundleId        String    @map("bundle_id") @db.Uuid
  url             String    @db.VarChar(500)
  secret          String?   @db.VarChar(255)
  events          String
  isActive        Boolean   @default(true) @map("is_active")
  failureCount    Int       @default(0) @map("failure_count")
  lastTriggeredAt DateTime? @map("last_triggered_at") @db.Timestamp(6)
  createdAt       DateTime  @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @map("updated_at") @db.Timestamp(6)

  bundle Bundles @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([bundleId], map: "bundle_webhooks_bundle_id")
  @@index([isActive], map: "bundle_webhooks_is_active")
  @@map("bundle_webhooks")
}

model BundleOrderItems {
  id          String  @id @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  productType String  @map("product_type") @db.VarChar(30)
  productId   String  @map("product_id") @db.VarChar(50)
  productName String? @map("product_name") @db.VarChar(255)
  price       Float
  currency    String  @default("VND") @db.VarChar(10)
  quantity    Int     @default(1)

  order BundleOrders @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([orderId], map: "bundle_order_items_order_id")
  @@map("bundle_order_items")
}

model BundlePaymentLogs {
  id         String   @id @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  provider   String   @db.VarChar(50)
  event      String   @db.VarChar(100)
  rawPayload String   @map("raw_payload")
  status     String   @default("received") @db.VarChar(30)
  createdAt  DateTime @map("created_at") @db.Timestamp(6)

  order BundleOrders @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([createdAt], map: "bundle_payment_logs_created_at")
  @@index([orderId], map: "bundle_payment_logs_order_id")
  @@index([status], map: "bundle_payment_logs_status")
  @@map("bundle_payment_logs")
}

model BundleRefundRequests {
  id         String   @id @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  reason     String
  amount     Float
  status     String   @default("pending") @db.VarChar(30)
  reviewedBy String?  @map("reviewed_by") @db.Uuid
  reviewNote String?  @map("review_note")
  createdAt  DateTime @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime @map("updated_at") @db.Timestamp(6)

  order    BundleOrders @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  reviewer User?        @relation("RefundReviewedBy", fields: [reviewedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  user     User         @relation("RefundUser", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([orderId], map: "bundle_refund_requests_order_id")
  @@index([status], map: "bundle_refund_requests_status")
  @@index([userId], map: "bundle_refund_requests_user_id")
  @@map("bundle_refund_requests")
}

model BundleUserEntitlements {
  id              String    @id @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  bundleId        String    @map("bundle_id") @db.Uuid
  orderId         String?   @map("order_id") @db.Uuid
  entitlementType String    @map("entitlement_type") @db.VarChar(30)
  expiresAt       DateTime? @map("expires_at") @db.Timestamp(6)
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @map("updated_at") @db.Timestamp(6)

  bundle Bundles       @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  order  BundleOrders? @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  user   User          @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([userId, bundleId, entitlementType])
  @@index([bundleId], map: "bundle_user_entitlements_bundle_id")
  @@index([isActive], map: "bundle_user_entitlements_is_active")
  @@index([userId], map: "bundle_user_entitlements_user_id")
  @@map("bundle_user_entitlements")
}

model BundleRollouts {
  id             String    @id @db.Uuid
  bundleId       String    @map("bundle_id") @db.Uuid
  trackId        String    @map("track_id") @db.Uuid
  rolloutPercent Int       @default(0) @map("rollout_percent")
  targetCountry  String?   @map("target_country") @db.VarChar(5)
  startedAt      DateTime  @map("started_at") @db.Timestamp(6)
  completedAt    DateTime? @map("completed_at") @db.Timestamp(6)
  createdAt      DateTime  @map("created_at") @db.Timestamp(6)

  bundle Bundles             @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  track  BundleReleaseTracks @relation(fields: [trackId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([bundleId], map: "bundle_rollouts_bundle_id")
  @@map("bundle_rollouts")
}

model BundleReviewReports {
  id          String   @id @db.Uuid
  reviewId    String   @map("review_id") @db.Uuid
  reportedBy  String   @map("reported_by") @db.Uuid
  reason      String   @db.VarChar(100)
  description String?
  status      String   @default("pending") @db.VarChar(30)
  reviewedBy  String?  @map("reviewed_by") @db.Uuid
  createdAt   DateTime @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @map("updated_at") @db.Timestamp(6)

  reporter User          @relation("ReviewReportReportedBy", fields: [reportedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  review   BundleReviews @relation(fields: [reviewId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  reviewer User?         @relation("ReviewReportReviewedBy", fields: [reviewedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([reviewId, reportedBy])
  @@index([reviewId], map: "bundle_review_reports_review_id")
  @@index([status], map: "bundle_review_reports_status")
  @@map("bundle_review_reports")
}

model BundleSubscriptionHistory {
  id           String    @id @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  planId       String    @map("plan_id") @db.Uuid
  bundleId     String    @map("bundle_id") @db.Uuid
  startAt      DateTime  @map("start_at") @db.Timestamp(6)
  endAt        DateTime? @map("end_at") @db.Timestamp(6)
  status       String    @default("active") @db.VarChar(30)
  cancelReason String?   @map("cancel_reason")
  createdAt    DateTime  @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime  @map("updated_at") @db.Timestamp(6)

  bundle Bundles                 @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  plan   BundleSubscriptionPlans @relation(fields: [planId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  user   User                    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([bundleId], map: "bundle_subscription_history_bundle_id")
  @@index([planId], map: "bundle_subscription_history_plan_id")
  @@index([status], map: "bundle_subscription_history_status")
  @@index([userId], map: "bundle_subscription_history_user_id")
  @@map("bundle_subscription_history")
}

model BundleCrashReports {
  id              String   @id @db.Uuid
  bundleId        String   @map("bundle_id") @db.Uuid
  versionId       String?  @map("version_id") @db.Uuid
  deviceModel     String?  @map("device_model") @db.VarChar(100)
  osVersion       String?  @map("os_version") @db.VarChar(30)
  platform        String?  @db.VarChar(20)
  stackTraceHash  String   @map("stack_trace_hash") @db.VarChar(64)
  stackTrace      String?  @map("stack_trace")
  occurrenceCount Int      @default(1) @map("occurrence_count")
  affectedUsers   Int      @default(1) @map("affected_users")
  firstSeen       BigInt   @map("first_seen")
  lastSeen        BigInt   @map("last_seen")
  isResolved      Boolean  @default(false) @map("is_resolved")
  createdAt       DateTime @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime @map("updated_at") @db.Timestamp(6)

  bundle  Bundles               @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  version BundleVersionHistory? @relation(fields: [versionId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([bundleId, versionId, stackTraceHash])
  @@index([bundleId], map: "bundle_crash_reports_bundle_id")
  @@index([isResolved], map: "bundle_crash_reports_is_resolved")
  @@index([lastSeen], map: "bundle_crash_reports_last_seen")
  @@index([stackTraceHash], map: "bundle_crash_reports_stack_trace_hash")
  @@map("bundle_crash_reports")
}

model BundleReviewHistory {
  id        String   @id @db.Uuid
  bundleId  String   @map("bundle_id") @db.Uuid
  versionId String?  @map("version_id") @db.Uuid
  action    String   @db.VarChar(30)
  actorId   String   @map("actor_id") @db.Uuid
  reason    String?
  metadata  String?
  createdAt DateTime @map("created_at") @db.Timestamp(6)

  actor   User                  @relation(fields: [actorId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  bundle  Bundles               @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  version BundleVersionHistory? @relation(fields: [versionId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([action], map: "bundle_review_history_action")
  @@index([bundleId], map: "bundle_review_history_bundle_id")
  @@index([createdAt], map: "bundle_review_history_created_at")
  @@map("bundle_review_history")
}

model BundleReviewQueue {
  id                 String    @id @db.Uuid
  bundleId           String    @map("bundle_id") @db.Uuid
  submittedVersionId String?   @map("submitted_version_id") @db.Uuid
  status             String    @default("pending") @db.VarChar(30)
  reviewerId         String?   @map("reviewer_id") @db.Uuid
  priority           Int       @default(0)
  reviewedAt         DateTime? @map("reviewed_at") @db.Timestamp(6)
  notes              String?
  createdAt          DateTime  @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime  @map("updated_at") @db.Timestamp(6)

  bundle           Bundles               @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  reviewer         User?                 @relation("ReviewQueueReviewer", fields: [reviewerId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  submittedVersion BundleVersionHistory? @relation(fields: [submittedVersionId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([bundleId], map: "bundle_review_queue_bundle_id")
  @@index([createdAt], map: "bundle_review_queue_created_at")
  @@index([priority], map: "bundle_review_queue_priority")
  @@index([status], map: "bundle_review_queue_status")
  @@map("bundle_review_queue")
}

model BundleSecurityScanResults {
  id             String   @id @db.Uuid
  bundleId       String   @map("bundle_id") @db.Uuid
  versionId      String?  @map("version_id") @db.Uuid
  scanType       String   @map("scan_type") @db.VarChar(50)
  result         String   @db.VarChar(20)
  severity       String?  @db.VarChar(20)
  findings       String?
  scannedAt      DateTime @map("scanned_at") @db.Timestamp(6)
  scannerVersion String?  @map("scanner_version") @db.VarChar(30)

  bundle  Bundles               @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  version BundleVersionHistory? @relation(fields: [versionId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([bundleId], map: "bundle_security_scan_results_bundle_id")
  @@index([result], map: "bundle_security_scan_results_result")
  @@index([scannedAt], map: "bundle_security_scan_results_scanned_at")
  @@map("bundle_security_scan_results")
}

model BundleUpdatePhases {
  id            String    @id @db.Uuid
  bundleId      String    @map("bundle_id") @db.Uuid
  versionId     String    @map("version_id") @db.Uuid
  phaseOrder    Int       @map("phase_order")
  percentage    Int
  targetCountry String?   @map("target_country") @db.VarChar(5)
  startedAt     DateTime? @map("started_at") @db.Timestamp(6)
  endedAt       DateTime? @map("ended_at") @db.Timestamp(6)
  status        String    @default("pending") @db.VarChar(20)
  createdAt     DateTime  @map("created_at") @db.Timestamp(6)

  bundle  Bundles              @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  version BundleVersionHistory @relation(fields: [versionId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([bundleId], map: "bundle_update_phases_bundle_id")
  @@map("bundle_update_phases")
}

model UserSecrets {
  id             String   @id @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  provider       String   @db.VarChar(64)
  encryptedValue String   @map("encrypted_value")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  // Relation to User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("user_secrets")
}

// ----------------------------------------------------
// New Models for Phase 9-18
// ----------------------------------------------------

model PersonalAccessToken {
  id          String    @id @default(cuid())
  name        String
  tokenHash   String    @unique
  scopes      String[]  // e.g., ["project:read", "project:write", "deployment:trigger"]
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  lastUsedAt  DateTime?

  @@map("personal_access_tokens")
}

model SsoConfig {
  id             String       @id @default(cuid())
  domain         String       @unique // e.g., "company.com"
  provider       String       // "saml" hoặc "oidc"
  clientId       String
  clientSecret   String?      // Mã hóa
  entryPoint     String       // SAML SSO URL
  issuer         String       // Identity Provider Entity ID
  cert           String       // Public Certificate PEM
  organizationId String       @unique @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@map("sso_configs")
}

model DeployHook {
  id          String    @id @default(cuid())
  name        String
  token       String    @unique // Random secure string
  branch      String    // Branch để build (e.g., "main")
  projectId   String    @db.Uuid
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  @@map("deploy_hooks")
}

model FirewallRule {
  id          String    @id @default(cuid())
  name        String
  action      String    // "block" (chặn), "allow" (cho phép), "challenge" (JS challenge)
  type        String    // "ip", "country", "path", "header"
  value       String    // e.g., "192.168.1.1", "CN", "/admin/*", "User-Agent:BadBot"
  active      Boolean   @default(true)
  projectId   String    @db.Uuid
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@map("firewall_rules")
}

model NativeDeployment {
  id              String    @id @default(cuid())
  projectId       String    @db.Uuid
  project         Project   @relation("ProjectNativeDeployments", fields: [projectId], references: [id], onDelete: Cascade)
  activeProjects  Project[] @relation("ProjectActiveNativeDeployment")
  target          String    @default("production") @db.VarChar(30)
  status          String    @default("queued") @db.VarChar(30)
  version         String    @db.VarChar(80)
  buildNumber     Int?      @map("build_number")
  bundleUrl       String?   @map("bundle_url") @db.VarChar(500)
  storageProvider String    @default("local") @map("storage_provider") @db.VarChar(40)
  storagePath     String    @map("storage_path") @db.VarChar(500)
  sourceCommit    String?   @map("source_commit") @db.VarChar(80)
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  activatedAt     DateTime? @map("activated_at")

  sourceMaps NativeSourceMap[]
  regionReplicas NativeRegionReplica[]
  artifactMirrors NativeArtifactMirror[]

  @@index([projectId, status], map: "native_deployments_project_status")
  @@index([projectId, target], map: "native_deployments_project_target")
  @@map("native_deployments")
}

model NativeDomainConfig {
  id             String    @id @default(cuid())
  domain         String    @unique @db.VarChar(255)
  projectId      String    @db.Uuid
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dnsVerified    Boolean   @default(false) @map("dns_verified")
  sslStatus      String    @default("PENDING") @map("ssl_status") @db.VarChar(30)
  certIssuedAt   DateTime? @map("cert_issued_at")
  certExpiresAt  DateTime? @map("cert_expires_at")
  lastDnsCheckAt DateTime? @map("last_dns_check_at")
  txtRecordToken String    @unique @map("txt_record_token") @db.VarChar(255)
  certPemRef     String?   @map("cert_pem_ref") @db.VarChar(500)
  keyPemRef      String?   @map("key_pem_ref") @db.VarChar(500)
  dnsProvider    String?   @map("dns_provider") @db.VarChar(50)
  dnsCredentials Json?     @map("dns_credentials")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([projectId], map: "native_domain_configs_project_id")
  @@index([sslStatus], map: "native_domain_configs_ssl_status")
  @@map("native_domain_configs")
}

model NativeEdgeFunction {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(120)
  routePath   String   @map("route_path") @db.VarChar(255)
  codeUrl     String   @map("code_url") @db.VarChar(500)
  memoryLimit Int      @default(128) @map("memory_limit")
  timeoutMs   Int      @default(50) @map("timeout_ms")
  status      String   @default("active") @db.VarChar(30)
  projectId   String   @db.Uuid
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([projectId, routePath])
  @@index([projectId], map: "native_edge_functions_project_id")
  @@map("native_edge_functions")
}

model NativeCacheEntry {
  id              String    @id @default(cuid())
  projectId       String    @db.Uuid
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  path            String    @db.VarChar(500)
  cacheKey        String    @unique @map("cache_key") @db.VarChar(700)
  contentType     String?   @map("content_type") @db.VarChar(120)
  bodyRef         String?   @map("body_ref") @db.VarChar(500)
  etag            String?   @db.VarChar(120)
  tags            String[]  @default([])
  surrogateKeys   String[]  @default([]) @map("surrogate_keys")
  compressionType String    @default("none") @map("compression_type") @db.VarChar(20)
  compressedSize  Int?      @map("compressed_size")
  rawSize         Int?      @map("raw_size")
  status          String    @default("fresh") @db.VarChar(30)
  hitCount        Int       @default(0) @map("hit_count")
  lastAccessedAt  DateTime? @map("last_accessed_at")
  staleAt         DateTime? @map("stale_at")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([projectId, path], map: "native_cache_entries_project_path")
  @@index([projectId, status], map: "native_cache_entries_project_status")
  @@index([expiresAt], map: "native_cache_entries_expires_at")
  @@map("native_cache_entries")
}

model NativeAnalyticsReplay {
  id          String   @id @default(cuid())
  projectId   String   @db.Uuid
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessionId   String   @map("session_id") @db.VarChar(120)
  userId      String?  @map("user_id") @db.Uuid
  url         String?  @db.VarChar(500)
  userAgent   String?  @map("user_agent")
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  events      Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([projectId, sessionId])
  @@index([projectId, createdAt], map: "native_analytics_replay_project_created")
  @@map("native_analytics_replays")
}

model NativeCrashReport {
  id             String   @id @default(cuid())
  projectId      String   @db.Uuid
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment    String   @default("production") @db.VarChar(40)
  errorMessage   String   @map("error_message")
  errorStack     String   @map("error_stack")
  parsedStack    Json?    @map("parsed_stack")
  fingerprint    String   @db.VarChar(128)
  platform       String   @db.VarChar(30)
  releaseVersion String   @map("release_version") @db.VarChar(80)
  userAgent      String?  @map("user_agent")
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  isResolved     Boolean  @default(false) @map("is_resolved")
  createdAt      DateTime @default(now()) @map("created_at")

  diagnostics NativeAiDiagnostic[]

  @@index([projectId, fingerprint], map: "native_crash_reports_project_fingerprint")
  @@index([projectId, createdAt], map: "native_crash_reports_project_created")
  @@map("native_crash_reports")
}

model NativeSourceMap {
  id             String            @id @default(cuid())
  projectId      String            @db.Uuid
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deploymentId   String?
  deployment     NativeDeployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  releaseVersion String            @map("release_version") @db.VarChar(80)
  fileName       String            @map("file_name") @db.VarChar(255)
  storagePath    String            @map("storage_path") @db.VarChar(500)
  mapJson        Json?             @map("map_json")
  uploadedAt     DateTime          @default(now()) @map("uploaded_at")

  @@unique([projectId, releaseVersion, fileName])
  @@index([deploymentId], map: "native_source_maps_deployment_id")
  @@map("native_source_maps")
}

model NativePlugin {
  id          String   @id @default(cuid())
  slug        String   @unique @db.VarChar(120)
  name        String   @db.VarChar(180)
  version     String   @db.VarChar(60)
  description String?
  bundleUrl   String   @map("bundle_url") @db.VarChar(500)
  permissions String[]
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  installations NativePluginInstallation[]

  @@map("native_plugins")
